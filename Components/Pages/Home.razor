@page "/"

<div class="hero">
    <h1>📖 Библиотека Online</h1>
    <p>Удобный поиск, добавление и управление каталогом книг</p>
    <a href="/search" class="btn-primary">Перейти к поиску</a>
</div>

<div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; max-width: 800px; margin: 0 auto;">

    <div class="card" style="text-align: center;">
        <div style="font-size: 2.5rem; margin-bottom: 1rem;">➕</div>
        <h3 style="color: var(--lavender-accent); margin-bottom: 0.5rem;">Добавить книгу</h3>
        <p style="color: var(--text-muted);">Расширение каталога новыми изданиями</p>
        <a href="/addbook" class="btn-secondary">Открыть</a>
    </div>
    
    <div class="card" style="text-align: center;">
        <div style="font-size: 2.5rem; margin-bottom: 1rem;">📚</div>
        <h3 style="color: var(--lavender-accent); margin-bottom: 0.5rem;">Все книги</h3>
        <p style="color: var(--text-muted);">Полный каталог доступных изданий</p>
        <a href="/api/books" target="_blank" class="btn-secondary">Смотреть</a>
    </div>
</div>