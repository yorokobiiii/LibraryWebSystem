@page "/search"
@using LibraryWebSystem.Services
@using LibraryWebSystem.Models
@rendermode InteractiveServer
@inject ISearchService SearchService

<h2 style="color: var(--lavender-accent); margin-bottom: 1.5rem;">🔍 Поиск книг</h2>

<div class="card" style="max-width: 800px; margin: 0 auto;">
    <form @onsubmit="PerformSearch">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div>
                <label class="form-label">Название книги</label>
                <input @bind="title" class="form-control" placeholder="Например: Мастер и Маргарита" />
            </div>
            <div>
                <label class="form-label">Автор</label>
                <input @bind="author" class="form-control" placeholder="Например: Булгаков" />
            </div>
            <div>
                <label class="form-label">Год от</label>
                <input @bind="yearFrom" type="number" class="form-control" placeholder="2000" />
            </div>
            <div>
                <label class="form-label">Год до</label>
                <input @bind="yearTo" type="number" class="form-control" placeholder="2026" />
            </div>
        </div>

        <div style="margin-top: 1rem;">
            <label class="form-label">Формат файла</label>
            <select @bind="format" class="form-select">
                <option value="">Все форматы</option>
                <option value="PDF">PDF</option>
                <option value="EPUB">EPUB</option>
                <option value="FB2">FB2</option>
            </select>
        </div>

        <div style="text-align: right; margin-top: 1.5rem;">
            <button type="submit" class="btn-primary">Найти</button>
        </div>
    </form>
</div>

@if (isSearched)
{
    <div style="margin-top: 2rem;">
        @if (results != null && results.Any())
        {
            <h3 style="color: var(--lavender-dark); margin-bottom: 1rem;">Найдено книг: @results.Count</h3>
            <table class="table">
                <thead>
                    <tr>
                        <th>Название</th>
                        <th>Год</th>
                        <th>Цена</th>
                        <th>Формат</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var book in results)
                    {
                        <tr>
                            <td><strong>@book.Title</strong></td>
                            <td>@book.YearPublished</td>
                            <td>@book.Price ₽</td>
                            <td><span class="badge">@book.FileFormat</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="alert alert-warning">По вашему запросу ничего не найдено.</div>
        }
    </div>
}

@code {
    private string? title, author, format;
    private int? yearFrom, yearTo;
    private List<Book>? results;
    private bool isSearched = false;

    private async Task PerformSearch()
    {
        results = await SearchService.SearchAsync(title, author, yearFrom, yearTo, format);
        isSearched = true;
    }
}