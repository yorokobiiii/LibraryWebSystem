@page "/addbook"
@using LibraryWebSystem.Models
@using LibraryWebSystem.Data
@using Microsoft.EntityFrameworkCore
@rendermode InteractiveServer
@inject LibraryContext Db

<h2 style="color: var(--lavender-accent); margin-bottom: 1.5rem;">➕ Добавить новую книгу</h2>

<div class="card" style="max-width: 700px; margin: 0 auto;">
    <EditForm Model="@book" OnValidSubmit="SaveBook">
        <DataAnnotationsValidator />
        <ValidationSummary class="alert alert-warning" />

        <label class="form-label">Название книги *</label>
        <InputText @bind-Value="book.Title" class="form-control" placeholder="Введите название" />
        <ValidationMessage For="@(() => book.Title)" style="color: #dc2626; font-size: 0.9rem;" />

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1rem;">
            <div>
                <label class="form-label">ISBN</label>
                <InputText @bind-Value="book.ISBN" class="form-control" placeholder="978-5-..." />
            </div>
            <div>
                <label class="form-label">Год издания</label>
                <InputNumber @bind-Value="book.YearPublished" class="form-control" />
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1rem;">
            <div>
                <label class="form-label">Цена (₽)</label>
                <InputNumber @bind-Value="book.Price" class="form-control" step="0.01" />
            </div>
            <div>
                <label class="form-label">Формат файла</label>
                <InputSelect @bind-Value="book.FileFormat" class="form-select">
                    <option value="PDF">PDF</option>
                    <option value="EPUB">EPUB</option>
                    <option value="FB2">FB2</option>
                </InputSelect>
            </div>
        </div>

        <div style="margin-top: 1rem;">
            <label class="form-label">Имя автора (для связи)</label>
            <InputText @bind-Value="authorName" class="form-control" placeholder="Например: Лев Толстой" />
            <small style="color: var(--text-muted);">Если автор уже есть в базе, книга свяжется с ним автоматически.</small>
        </div>

        <div style="margin-top: 2rem; display: flex; gap: 1rem;">
            <button type="submit" class="btn-primary">💾 Сохранить</button>
            <a href="/search" class="btn-secondary">↩️ Назад</a>
        </div>
    </EditForm>

    @if (showSuccess)
    {
        <div class="alert alert-success">✅ Книга "@book.Title" успешно добавлена!</div>
    }
</div>

@code {
    private Book book = new();
    private string? authorName;
    private bool showSuccess = false;

    private async Task SaveBook()
    {
        showSuccess = false;
        try
        {
            if (!string.IsNullOrWhiteSpace(authorName))
            {
                var names = authorName.Split(' ', 2);
                var firstName = names.Length > 0 ? names[0] : "";
                var lastName = names.Length > 1 ? names[1] : "";

                var author = await Db.Authors.FirstOrDefaultAsync(a => a.FirstName == firstName && a.LastName == lastName);

                if (author == null)
                {
                    author = new Author { FirstName = firstName, LastName = lastName };
                    Db.Authors.Add(author);
                    await Db.SaveChangesAsync();
                }

                Db.BookAuthors.Add(new BookAuthor { Book = book, Author = author, Role = "Автор" });
            }

            Db.Books.Add(book);
            await Db.SaveChangesAsync();

            showSuccess = true;
            book = new Book();
            authorName = null;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка: {ex.Message}");
        }
    }
}